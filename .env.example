# API Keys
SAM_GOV_API_KEY=your-sam-gov-key-here
CENSUS_API_KEY=your-census-key-here

# Firestore
FIRESTORE_PROJECT_ID=leadgen-mvp-local
FIRESTORE_EMULATOR_HOST=localhost:8681
GOOGLE_CLOUD_PROJECT=leadgen-mvp-local

# Storage (local filesystem for dev)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/raw

# Service URLs (local dev)
ETL_PIPELINE_URL=http://localhost:8003

# Logging
LOG_LEVEL=DEBUG
ENVIRONMENT=development
